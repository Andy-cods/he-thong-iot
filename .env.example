# =============================================================
# he-thong-iot — Local developer env template
# Copy file này thành `.env.local` ở root hoặc `apps/web/.env.local`
# rồi điền giá trị thật. KHÔNG commit file có secret thật.
# =============================================================

# --- Database (PostgreSQL 16) ---
# Local dev có thể dùng Postgres riêng; production dùng chung instance Song Châu
# với DB `hethong_iot`, role `hethong_app`.
DATABASE_URL=postgres://hethong_app:changeme@localhost:5432/hethong_iot

# --- Redis (BullMQ + cache) ---
# Production: chung Redis Song Châu nhưng db=2
REDIS_URL=redis://localhost:6379/2
BULLMQ_PREFIX=iot-

# --- Auth ---
# JWT access token secret (min 32 char). Generate bằng: openssl rand -hex 32
JWT_SECRET=replace-with-openssl-rand-hex-32
# Session/refresh cookie secret (khác JWT_SECRET)
SESSION_SECRET=replace-with-another-openssl-rand-hex-32
# Access token TTL (seconds), refresh token TTL (seconds)
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=604800

# --- App URL (dùng cho cookie domain, CORS, mail link) ---
APP_URL=http://localhost:3001
NODE_ENV=development

# --- Cloudflare R2 (S3-compatible object storage) ---
R2_ACCOUNT_ID=your-cf-account-id
R2_ACCESS_KEY_ID=your-r2-access-key
R2_SECRET_ACCESS_KEY=your-r2-secret-key
R2_BUCKET=hethong-iot-files
R2_ENDPOINT=https://your-cf-account-id.r2.cloudflarestorage.com
R2_PUBLIC_URL=https://files.iot.domain.vn

# --- Telegram alert (health-check, backup fail) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Log level ---
LOG_LEVEL=info

# --- OpenTelemetry / Grafana Cloud (V1.4 Phase E) ---
# Nếu để trống → SDK skip init (không crash local dev).
# Endpoint Grafana Cloud OTLP gateway (vùng EU/US tuỳ account).
# Ví dụ: https://otlp-gateway-prod-eu-west-2.grafana.net/otlp
OTEL_EXPORTER_OTLP_ENDPOINT=
# Header auth Basic base64("instanceID:apiKey"). Nếu set GRAFANA_CLOUD_TOKEN
# riêng, SDK tự thêm header `authorization: Basic <token>`.
OTEL_EXPORTER_OTLP_HEADERS=
GRAFANA_CLOUD_TOKEN=
# Service name hiển thị trên Grafana (default: iot-web)
OTEL_SERVICE_NAME=iot-web

# --- RLS (V1.4 Phase B) ---
# Bật Row-Level Security cho app runtime. Khi `true`, helper withRoleTx
# sẽ SET LOCAL ROLE iot_<role> đầu mỗi transaction → PG policy fire.
# Default `false` để không break deploy hiện hành.
# Bật sau khi apply migration 0007a_rls_policies.sql + smoke test 40 cell.
RLS_ENABLED=false

export CLAUDE_CODE_EFFORT_LEVEL=max
export CLAUDE_CODE_DISABLE_ADAPTIVE_THINKING=1
export MAX_THINKING_TOKENS=63999
export CLAUDE_CODE_DISABLE_1M_CONTEXT=1
export DISABLE_TELEMETRY=1