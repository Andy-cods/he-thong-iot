{
  "name": "he-thong-iot",
  "version": "0.1.0",
  "private": true,
  "description": "BOM-centric MES/ERP nhẹ cho xưởng cơ khí Việt Nam — monorepo V1",
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20.11.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "dev": "pnpm -r --parallel --filter=./apps/* dev",
    "dev:web": "pnpm --filter @iot/web dev",
    "dev:worker": "pnpm --filter @iot/worker dev",
    "build": "pnpm -r --filter=./apps/* --filter=./packages/* build",
    "start:web": "pnpm --filter @iot/web start",
    "start:worker": "pnpm --filter @iot/worker start",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "db:generate": "pnpm --filter @iot/db generate",
    "db:push": "pnpm --filter @iot/db push",
    "db:migrate": "pnpm --filter @iot/db migrate",
    "db:seed": "pnpm --filter @iot/db seed",
    "db:studio": "pnpm --filter @iot/db studio",
    "clean": "pnpm -r exec rm -rf dist .next .turbo node_modules"
  },
  "devDependencies": {
    "@types/node": "^20.12.7",
    "typescript": "^5.5.4",
    "prettier": "^3.3.3",
    "eslint": "^8.57.0"
  }
}
