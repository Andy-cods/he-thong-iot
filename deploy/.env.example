# =============================================================
# deploy/.env — template biến môi trường cho docker compose
# Copy thành `deploy/.env` trên VPS rồi điền giá trị thật.
# KHÔNG commit file có giá trị thật.
# =============================================================

# Image tag (build ở CI rồi push registry hoặc `docker load` tar)
IOT_IMAGE=registry.local/hethong-iot:v0.1.0

# URL công khai
# Chưa có domain → dùng IP + port: http://103.56.158.129:8443
# Có domain sau này → đổi sang https://iot.your-domain.vn
APP_URL=http://103.56.158.129:8443

# Cloudflare R2 (non-secret config; secret key đi qua file secrets/)
R2_ACCOUNT_ID=your-cf-account-id
R2_BUCKET=hethong-iot-files
R2_ENDPOINT=https://your-cf-account-id.r2.cloudflarestorage.com
R2_PUBLIC_URL=https://pub-xxx.r2.dev  # dùng R2 public dev URL cho đến khi có domain tuỳ chỉnh

# Telegram alert (dùng cho health-check.sh và backup.sh)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# =============================================================
# File secrets (tạo trong ./secrets/ trước khi `docker compose up`):
#   db_password.txt       — password Postgres role hethong_app (openssl rand -base64 24)
#   jwt_secret.txt        — openssl rand -hex 32
#   session_secret.txt    — openssl rand -hex 32
#   r2_access_key.txt     — R2 access key id
#   r2_secret_key.txt     — R2 secret access key
#
# chmod 600 secrets/*.txt ; chown root:root (hoặc user chạy docker).
# =============================================================
